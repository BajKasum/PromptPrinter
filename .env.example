# ─── Public / client-side ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Server-side only (NEVER prefix with NEXT_PUBLIC_) ────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI provider — Gemini powers /api/generate. Without a key the endpoint
# returns the prompt templates unchanged (stub mode), so the flow still works.
GEMINI_API_KEY=...
# Optional — override the model (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# Stripe billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# Rate limiting — Upstash (optional, recommended for prod)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
