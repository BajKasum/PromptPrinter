# Version control
.git
.gitignore
.gitattributes

# Build / dependency artifacts (rebuilt inside the image)
node_modules
.next
out
build
dist
*.tsbuildinfo

# Environment — never bake real secrets into the image
.env
.env.local
.env.*.local
.env.docker
!.env.example
!.env.docker.example

# IDE / editor / OS
.vscode
.idea
*.swp
.DS_Store
Thumbs.db

# Logs & caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo
.cache
coverage

# Design references (regenerate from Stitch MCP if needed)
.stitch-refs

# Docker meta (no point copying into the build context)
Dockerfile
.dockerignore
docker-compose*.yml

# Misc
README.md
LICENSE
